//    <name> MDSEL </name>
//    <rw> 
//    <i> [Bit 5] RW (@ 0x30001000) \nCRC/Checksum Selection\n0 : CRC = Select CRC.\n1 : Checksum = Select Checksum. </i>
//    <combo> 
//      <loc> ( (unsigned int) CRC_CR ) </loc>
//      <o.5..5> MDSEL
//        <0=> 0: CRC = Select CRC.
//        <1=> 1: Checksum = Select Checksum.
//    </combo>
